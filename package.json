{
  "name": "squared",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered real-time speech coaching.",
  "author": "Ivan Habor",
  "license": "MIT",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,server \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "predev:server": "node scripts/ensure-better-sqlite3-node.mjs",
    "dev:server": "tsx server/index.ts",
    "dev:desktop": "concurrently -k -n server,web,electron \"npm:dev:server\" \"npm:dev:web\" \"wait-on tcp:3000 tcp:3001 && npm run electron:dev\"",
    "build": "npm run build:web && npm run build:server && npm run build:electron",
    "build:desktop": "node scripts/build-desktop.mjs",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "copy:desktop-resources": "node electron/scripts/copy-resources.mjs",
    "native:restore-node": "node scripts/ensure-better-sqlite3-node.mjs --force",
    "package:desktop": "electron-builder --mac dir",
    "preview": "vite preview",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "clean": "rm -rf dist dist-electron dist-server dist-resources release",
    "lint": "npm run lint:web && npm run lint:server && npm run lint:electron",
    "lint:web": "tsc -p tsconfig.json --noEmit",
    "lint:server": "tsc -p tsconfig.server.json --noEmit",
    "lint:electron": "tsc -p tsconfig.electron.json --noEmit",
    "electron:dev": "npm run build:electron && electron dist-electron/electron/main.js"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.2.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^36.1.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.squared.desktop",
    "productName": "Squared",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-server/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "dist-resources/electron",
        "to": "electron"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir"
      ]
    }
  }
}
