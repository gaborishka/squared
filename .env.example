# GEMINI_API_KEY: Required by the server for Gemini Live token minting,
# embeddings, and other server-side Gemini calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public web app URL for Squared.
# Used by web OAuth callbacks and hosted production routing.
APP_URL="https://your-cloud-run-service-url"

# Optional desktop/backend override for packaged builds.
# Use this when desktop should talk to a different backend URL than the web app.
DESKTOP_API_BASE_URL=""

# Optional generic API base override for browser/frontend builds.
# If set, packaged Electron uses this backend base URL instead of APP_URL.
VITE_API_BASE_URL=""

# Google OAuth: Required for hosted authentication.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Local Postgres for development.
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:55432/squared"
PGSSLMODE="disable"

# Optional Terraform state bucket override for deploys.
TF_STATE_BUCKET="your-project-squared-tfstate"

# Force overlay compositing for screen recording visibility.
# Set to "true" to make HUD overlays capturable by screen recorders.
VITE_FORCE_OVERLAY="false"
